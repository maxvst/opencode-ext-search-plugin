{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "types": ["vitest/globals"]
  },
  "include": [
    "tests/**/*.ts",
    "plugins/ext-search/src/**/*.ts",
    "vitest.config.ts",
    "vitest.config.integration.ts",
    "vitest.config.e2e.ts"
  ]
}
